model:
  base_url: "https://api.deepseek.com/v1"
  api_key: "sk-your-key-here"
  model_name: "deepseek-chat"
  max_tokens: 4096

server:
  host: "127.0.0.1"
  port: 8765

chat:
  max_history_rounds: 20

voice:
  # TTS engine: "edge" (Microsoft cloud, no GPU) | "f5" (F5-TTS, voice cloning)
  tts_engine: "edge"

  # Edge-tts voice (only used when tts_engine is "edge")
  tts_voice: "zh-CN-XiaoxiaoNeural"

  # F5-TTS settings (only used when tts_engine is "f5")
  f5:
    # Path to reference WAV audio for voice cloning (5-10s, any language)
    reference_audio: "assets/voice/reference.wav"
    # Reference text (optional — F5-TTS auto-transcribes if empty)
    reference_text: ""
    # Synthesis language
    language: "zh"
    # Use GPU acceleration
    use_gpu: true
